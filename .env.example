# ─── Rent a Husband — environment template ───
# Copy to .env and fill in real values. NEVER commit .env.
# Anything secret (service role key, WiPay keys) belongs ONLY in
# Supabase Edge Function / server env — not in the app bundle.

# ── Supabase (client-safe) ──
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase (server only — Edge Functions, NEVER in the app) ──
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── WiPay (server only — Edge Functions) ──
WIPAY_ACCOUNT_NUMBER=your-wipay-account-number
WIPAY_API_KEY=your-wipay-api-key
WIPAY_ENVIRONMENT=sandbox          # sandbox | live
WIPAY_CALLBACK_URL=https://your-project.functions.supabase.co/wipay-callback

# ── Maps / geocoding (client) ──
EXPO_PUBLIC_MAPS_API_KEY=your-maps-or-geocoding-key

# ── App config ──
EXPO_PUBLIC_DEFAULT_CURRENCY=TTD
EXPO_PUBLIC_LAUNCH_ZONE=            # e.g. a town/cluster slug
